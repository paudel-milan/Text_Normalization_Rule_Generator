    "80": "એંસી", "81": "એક્યાસી", "82": "બ્યાસી", "83": "ત્યાસી", "84": "ચોર્યાસી",
    "85": "પંચાસી", "86": "છ્યાસી", "87": "સિત્યાસી", "88": "ઈઠ્યાસી", "89": "નેવ્યાસી",
    "90": "નેવું", "91": "એકાણું", "92": "બાણું", "93": "ત્રાણું", "94": "ચોરાણું",
    "95": "પંચાણું", "96": "છન્નું", "97": "સત્તાણું", "98": "અઠ્ઠાણું", "99": "નવ્વાણું",
    "100": "સો",
    "1000": "હજાર",
    "100000": "લાખ",
    "10000000": "કરોડ"
  },

  "categories": {
    "cardinal": {
      "description": "Cardinal numbers (e.g., ૫૦૦, 1234)",
      "pattern_template": "({digits}+)",
      "tokens": {
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "cardinal",
        "template": "<say-as interpret-as=\"cardinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["૫૦૦", "૧૨૩૪", "100", "૦"],
        "negative": ["abc", "₹૫૦૦", ""]
      }
    },

    "ordinal": {
      "description": "Ordinal numbers (e.g., ૫મો, 3જો)",
      "suffixes": ["મો", "મી", "મું", "જો", "જી", "જું"],
      "pattern_template": "({digits}+)\\s*({suffixes})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "suffixes": "{suffix_alternation}"
      },
      "ssml": {
        "interpret_as": "ordinal",
        "template": "<say-as interpret-as=\"ordinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["૫મો", "૧મી", "10મું", "3જો"],
        "negative": ["૫", "મો", "abc"]
      }
    },

    "currency": {
      "description": "Currency amounts (e.g., ₹૫૦૦, $100.50)",
      "symbols": ["₹", "$"],
      "symbol_names": {
        "₹": "રૂપિયા",
        "$": "ડૉલર"
      },
      "decimal_separator": ".",
      "pattern_template": "({symbols})\\s*({digits}+)(?:\\.({digits}+))?",
      "tokens": {
        "symbols": "[{symbol_chars}]",
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "currency",
        "attributes": {
          "currency": "INR"
        },
        "template": "<say-as interpret-as=\"currency\">{value}</say-as>"
      },
      "normalization": {
        "format": "{amount_words} {currency_name}"
      },
      "test_cases": {
        "positive": ["₹૫૦૦", "₹૧૦", "$100", "₹50.75", "₹ 200"],
        "negative": ["500", "રૂપિયા", "₹"]
      }
    },

    "date": {
      "description": "Date expressions (e.g., ૧૫/૦૮/૨૦૨૩, 15-08-2023)",
      "separators": ["/", "-", "."],
      "month_names": [
        "જાન્યુઆરી", "ફેબ્રુઆરી", "માર્ચ", "એપ્રિલ", "મે", "જૂન",
        "જુલાઈ", "ઑગસ્ટ", "સપ્ટેમ્બર", "ઑક્ટોબર", "નવેમ્બર", "ડિસેમ્બર"
      ],
      "format_order": "DMY",
      "pattern_template": "({digits}{1,2}){separator}({digits}{1,2}){separator}({digits}{2,4})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "separator": "[{separator_chars}]"
      },
      "ssml": {
        "interpret_as": "date",
        "attributes": {
          "format": "dmy"
        },
        "template": "<say-as interpret-as=\"date\" format=\"dmy\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["૧૫/૦૮/૨૦૨૩", "15-08-2023", "01.12.2024"],
        "negative": ["15082023", "abc", "date-text"]
      }
    },

    "time": {
      "description": "Time expressions (e.g., ૫:૩૦, 14:30, 5:30 PM)",
      "period_markers": ["AM", "PM", "am", "pm", "સવારે", "સાંજે", "બપોરે", "રાત્રે"],
      "separator": ":",
      "pattern_template": "({digits}{1,2}):({digits}{2})(?:\\s*({periods}))?",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "periods": "{period_alternation}"
      },
      "ssml": {
        "interpret_as": "time",
        "attributes": {
          "format": "hms12"
        },
        "template": "<say-as interpret-as=\"time\" format=\"hms12\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["૫:૩૦", "14:30", "5:30 PM", "૩:૦૦ સવારે"],
        "negative": ["530", "5.30", "time-text"]
      }
    },

    "units": {
      "description": "Measurement units (e.g., ૫ કિલોગ્રામ, 100 km)",
      "unit_map": {
        "kg": "કિલોગ્રામ",
        "g": "ગ્રામ",
        "km": "કિલોમીટર",
        "m": "મીટર",
        "cm": "સેન્ટિમીટર",
        "mm": "મિલિમીટર",
        "l": "લીટર",
        "ml": "મિલિલીટર",
        "°C": "ડિગ્રી સેલ્સિયસ",
        "°F": "ડિગ્રી ફેરનહાઈટ",
        "km/h": "કિલોમીટર પ્રતિ કલાક",
        "mph": "માઈલ પ્રતિ કલાક",
        "કિલોગ્રામ": "કિલોગ્રામ",
        "ગ્રામ": "ગ્રામ",
        "કિલોમીટર": "કિલોમીટર",
        "મીટર": "મીટર",
        "સેન્ટિમીટર": "સેન્ટિમીટર",
        "લીટર": "લીટર",
        "મિલિલીટર": "મિલિલીટર"
      },
      "pattern_template": "({digits}+(?:\\.{digits}+)?)\\s*({unit_names})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "unit_names": "{unit_alternation}"
      },
      "ssml": {
        "interpret_as": "unit",
        "template": "<say-as interpret-as=\"unit\">{value} {unit_spoken}</say-as>"
      },
      "test_cases": {
        "positive": ["૫ કિલોગ્રામ", "100 km", "37.5 °C", "૧.૫ લીટર"],
        "negative": ["કિલોગ્રામ", "100", "km"]
      }
    }
  }
}
