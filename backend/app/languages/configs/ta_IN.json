  "categories": {
    "cardinal": {
      "description": "Cardinal numbers (e.g., ௫௦௦, 1234)",
      "pattern_template": "({digits}+)",
      "tokens": {
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "cardinal",
        "template": "<say-as interpret-as=\"cardinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["௫௦௦", "௧௨௩௪", "100", "௦"],
        "negative": ["abc", "₹௫௦௦", ""]
      }
    },

    "ordinal": {
      "description": "Ordinal numbers (e.g., ௫ஆம், 3வது)",
      "suffixes": ["ஆம்", "வது", "ஆவது"],
      "pattern_template": "({digits}+)\\s*({suffixes})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "suffixes": "{suffix_alternation}"
      },
      "ssml": {
        "interpret_as": "ordinal",
        "template": "<say-as interpret-as=\"ordinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["௫ஆம்", "௧வது", "10ஆம்", "3ஆவது"],
        "negative": ["௫", "ஆம்", "abc"]
      }
    },

    "currency": {
      "description": "Currency amounts (e.g., ₹௫௦௦, $100.50)",
      "symbols": ["₹", "$"],
      "symbol_names": {
        "₹": "ரூபாய்",
        "$": "டாலர்"
      },
      "decimal_separator": ".",
      "pattern_template": "({symbols})\\s*({digits}+)(?:\\.({digits}+))?",
      "tokens": {
        "symbols": "[{symbol_chars}]",
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "currency",
        "attributes": {
          "currency": "INR"
        },
        "template": "<say-as interpret-as=\"currency\">{value}</say-as>"
      },
      "normalization": {
        "format": "{amount_words} {currency_name}"
      },
      "test_cases": {
        "positive": ["₹௫௦௦", "₹௧௦", "$100", "₹50.75", "₹ 200"],
        "negative": ["500", "ரூபாய்", "₹"]
      }
    },

    "date": {
      "description": "Date expressions (e.g., ௧௫/௦௮/௨௦௨௩, 15-08-2023)",
      "separators": ["/", "-", "."],
      "month_names": [
        "ஜனவரி", "பிப்ரவரி", "மார்ச்", "ஏப்ரல்", "மே", "ஜூன்",
        "ஜூலை", "ஆகஸ்ட்", "செப்டம்பர்", "அக்டோபர்", "நவம்பர்", "டிசம்பர்"
      ],
      "format_order": "DMY",
      "pattern_template": "({digits}{1,2}){separator}({digits}{1,2}){separator}({digits}{2,4})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "separator": "[{separator_chars}]"
      },
      "ssml": {
        "interpret_as": "date",
        "attributes": {
          "format": "dmy"
        },
        "template": "<say-as interpret-as=\"date\" format=\"dmy\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["௧௫/௦௮/௨௦௨௩", "15-08-2023", "01.12.2024"],
        "negative": ["15082023", "abc", "date-text"]
      }
    },

    "time": {
      "description": "Time expressions (e.g., ௫:௩௦, 14:30, 5:30 PM)",
      "period_markers": ["AM", "PM", "am", "pm", "காலை", "மாலை", "நண்பகல்", "இரவு"],
      "separator": ":",
      "pattern_template": "({digits}{1,2}):({digits}{2})(?:\\s*({periods}))?",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "periods": "{period_alternation}"
      },
      "ssml": {
        "interpret_as": "time",
        "attributes": {
          "format": "hms12"
        },
        "template": "<say-as interpret-as=\"time\" format=\"hms12\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["௫:௩௦", "14:30", "5:30 PM", "௩:௦௦ காலை"],
        "negative": ["530", "5.30", "time-text"]
      }
    },

    "units": {
      "description": "Measurement units (e.g., ௫ கிலோகிராம், 100 km)",
      "unit_map": {
        "kg": "கிலோகிராம்",
        "g": "கிராம்",
        "km": "கிலோமீட்டர்",
        "m": "மீட்டர்",
        "cm": "சென்டிமீட்டர்",
        "mm": "மில்லிமீட்டர்",
        "l": "லிட்டர்",
        "ml": "மில்லிலிட்டர்",
        "°C": "டிகிரி செல்சியஸ்",
        "°F": "டிகிரி ஃபாரன்ஹீட்",
        "km/h": "கிலோமீட்டர் ஒரு மணி நேரத்திற்கு",
        "mph": "மைல் ஒரு மணி நேரத்திற்கு",
        "கிலோகிராம்": "கிலோகிராம்",
        "கிராம்": "கிராம்",
        "கிலோமீட்டர்": "கிலோமீட்டர்",
        "மீட்டர்": "மீட்டர்",
        "சென்டிமீட்டர்": "சென்டிமீட்டர்",
        "லிட்டர்": "லிட்டர்",
        "மில்லிலிட்டர்": "மில்லிலிட்டர்"
      },
      "pattern_template": "({digits}+(?:\\.{digits}+)?)\\s*({unit_names})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "unit_names": "{unit_alternation}"
      },
      "ssml": {
        "interpret_as": "unit",
        "template": "<say-as interpret-as=\"unit\">{value} {unit_spoken}</say-as>"
      },
      "test_cases": {
        "positive": ["௫ கிலோகிராம்", "100 km", "37.5 °C", "௧.௫ லிட்டர்"],
        "negative": ["கிலோகிராம்", "100", "km"]
      }
    }
  }
}
