  "categories": {
    "cardinal": {
      "description": "Cardinal numbers (e.g., ౫౦౦, 1234)",
      "pattern_template": "({digits}+)",
      "tokens": {
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "cardinal",
        "template": "<say-as interpret-as=\"cardinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["౫౦౦", "౧౨౩౪", "100", "౦"],
        "negative": ["abc", "₹౫౦౦", ""]
      }
    },

    "ordinal": {
      "description": "Ordinal numbers (e.g., ౫వ, 3వ)",
      "suffixes": ["వ", "వా", "వది"],
      "pattern_template": "({digits}+)\\s*({suffixes})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "suffixes": "{suffix_alternation}"
      },
      "ssml": {
        "interpret_as": "ordinal",
        "template": "<say-as interpret-as=\"ordinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["౫వ", "౧వా", "10వ", "3వది"],
        "negative": ["౫", "వ", "abc"]
      }
    },

    "currency": {
      "description": "Currency amounts (e.g., ₹౫౦౦, $100.50)",
      "symbols": ["₹", "$"],
      "symbol_names": {
        "₹": "రూపాయలు",
        "$": "డాలర్లు"
      },
      "decimal_separator": ".",
      "pattern_template": "({symbols})\\s*({digits}+)(?:\\.({digits}+))?",
      "tokens": {
        "symbols": "[{symbol_chars}]",
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "currency",
        "attributes": {
          "currency": "INR"
        },
        "template": "<say-as interpret-as=\"currency\">{value}</say-as>"
      },
      "normalization": {
        "format": "{amount_words} {currency_name}"
      },
      "test_cases": {
        "positive": ["₹౫౦౦", "₹౧౦", "$100", "₹50.75", "₹ 200"],
        "negative": ["500", "రూపాయలు", "₹"]
      }
    },

    "date": {
      "description": "Date expressions (e.g., ౧౫/౦౮/౨౦౨౩, 15-08-2023)",
      "separators": ["/", "-", "."],
      "month_names": [
        "జనవరి", "ఫిబ్రవరి", "మార్చి", "ఏప్రిల్", "మే", "జూన్",
        "జులై", "ఆగస్టు", "సెప్టెంబర్", "అక్టోబర్", "నవంబర్", "డిసెంబర్"
      ],
      "format_order": "DMY",
      "pattern_template": "({digits}{1,2}){separator}({digits}{1,2}){separator}({digits}{2,4})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "separator": "[{separator_chars}]"
      },
      "ssml": {
        "interpret_as": "date",
        "attributes": {
          "format": "dmy"
        },
        "template": "<say-as interpret-as=\"date\" format=\"dmy\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["౧౫/౦౮/౨౦౨౩", "15-08-2023", "01.12.2024"],
        "negative": ["15082023", "abc", "date-text"]
      }
    },

    "time": {
      "description": "Time expressions (e.g., ౫:౩౦, 14:30, 5:30 PM)",
      "period_markers": ["AM", "PM", "am", "pm", "ఉదయం", "సాయంత్రం", "మధ్యాహ్నం", "రాత్రి"],
      "separator": ":",
      "pattern_template": "({digits}{1,2}):({digits}{2})(?:\\s*({periods}))?",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "periods": "{period_alternation}"
      },
      "ssml": {
        "interpret_as": "time",
        "attributes": {
          "format": "hms12"
        },
        "template": "<say-as interpret-as=\"time\" format=\"hms12\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["౫:౩౦", "14:30", "5:30 PM", "౩:౦౦ ఉదయం"],
        "negative": ["530", "5.30", "time-text"]
      }
    },

    "units": {
      "description": "Measurement units (e.g., ౫ కిలోగ్రాములు, 100 km)",
      "unit_map": {
        "kg": "కిలోగ్రాములు",
        "g": "గ్రాములు",
        "km": "కిలోమీటర్లు",
        "m": "మీటర్లు",
        "cm": "సెంటిమీటర్లు",
        "mm": "మిల్లిమీటర్లు",
        "l": "లీటర్లు",
        "ml": "మిల్లీలీటర్లు",
        "°C": "డిగ్రీల సెల్సియస్",
        "°F": "డిగ్రీల ఫారన్‌హీట్",
        "km/h": "కిలోమీటర్లు గంటకు",
        "mph": "మైళ్ళు గంటకు",
        "కిలోగ్రాములు": "కిలోగ్రాములు",
        "గ్రాములు": "గ్రాములు",
        "కిలోమీటర్లు": "కిలోమీటర్లు",
        "మీటర్లు": "మీటర్లు",
        "సెంటిమీటర్లు": "సెంటిమీటర్లు",
        "లీటర్లు": "లీటర్లు",
        "మిల్లీలీటర్లు": "మిల్లీలీటర్లు"
      },
      "pattern_template": "({digits}+(?:\\.{digits}+)?)\\s*({unit_names})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "unit_names": "{unit_alternation}"
      },
      "ssml": {
        "interpret_as": "unit",
        "template": "<say-as interpret-as=\"unit\">{value} {unit_spoken}</say-as>"
      },
      "test_cases": {
        "positive": ["౫ కిలోగ్రాములు", "100 km", "37.5 °C", "౧.౫ లీటర్లు"],
        "negative": ["కిలోగ్రాములు", "100", "km"]
      }
    }
  }
}
