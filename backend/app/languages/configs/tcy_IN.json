    "1000": "ಸಾವಿರ",
    "100000": "ಲಕ್ಷ",
    "10000000": "ಕೋಟಿ"
  },

  "categories": {
    "cardinal": {
      "description": "Cardinal numbers (e.g., ೫೦೦, 1234)",
      "pattern_template": "({digits}+)",
      "tokens": {
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "cardinal",
        "template": "<say-as interpret-as=\"cardinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["೫೦೦", "೧೨೩೪", "100", "೦"],
        "negative": ["abc", "₹೫೦೦", ""]
      }
    },

    "ordinal": {
      "description": "Ordinal numbers (e.g., ೫ನೇ, 3rd)",
      "suffixes": ["ನೇ", "ನೆ", "ಅನೆ"],
      "pattern_template": "({digits}+)\\s*({suffixes})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "suffixes": "{suffix_alternation}"
      },
      "ssml": {
        "interpret_as": "ordinal",
        "template": "<say-as interpret-as=\"ordinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["೫ನೇ", "೧ನೆ", "10ಅನೆ", "೩ನೇ"],
        "negative": ["೫", "ನೇ", "abc"]
      }
    },

    "currency": {
      "description": "Currency amounts (e.g., ₹೫೦೦, Rs 100)",
      "symbols": ["₹", "Rs", "ರು", "$"],
      "symbol_names": {
        "₹": "ರೂಪಾಯಿ",
        "Rs": "ರೂಪಾಯಿ",
        "ರು": "ರೂಪಾಯಿ",
        "$": "ಡಾಲರ್"
      },
      "decimal_separator": ".",
      "pattern_template": "({symbols})\\s*({digits}+)(?:\\.({digits}+))?",
      "tokens": {
        "symbols": "(?:{symbol_alternation})",
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "currency",
        "attributes": {
          "currency": "INR"
        },
        "template": "<say-as interpret-as=\"currency\">{value}</say-as>"
      },
      "normalization": {
        "format": "{amount_words} {currency_name}"
      },
      "test_cases": {
        "positive": ["₹೫೦೦", "Rs ೧೦೦", "₹ 200.50", "ರು೫೦"],
        "negative": ["500", "ರೂಪಾಯಿ", "₹"]
      }
    },

    "date": {
      "description": "Date expressions (e.g., ೧೫/೦೮/೨೦೨೩, 15-08-2023)",
      "separators": ["/", "-", "."],
      "month_names": [
        "ಜನವರಿ", "ಸೆಪ್ಟೆಂಬರ್", "ಮಾರ್ಚ್", "ಏಪ್ರಿಲ್", "ಮೇ", "ಜೂನ್",
        "ಜುಲೈ", "ಆಗಸ್ಟ್", "ಸೆಪ್ಟೆಂಬರ್", "ಅಕ್ಟೋಬರ್", "ನವೆಂಬರ್", "ಡಿಸೆಂಬರ್"
      ],
      "format_order": "DMY",
      "pattern_template": "({digits}{1,2}){separator}({digits}{1,2}){separator}({digits}{2,4})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "separator": "[{separator_chars}]"
      },
      "ssml": {
        "interpret_as": "date",
        "attributes": {
          "format": "dmy"
        },
        "template": "<say-as interpret-as=\"date\" format=\"dmy\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["೧೫/೦೮/೨೦೨೩", "15-08-2023", "01.12.2024"],
        "negative": ["15082023", "abc", "32/13/2023"]
      }
    },

    "time": {
      "description": "Time expressions (e.g., ೫:೩೦, 14:30)",
      "period_markers": ["AM", "PM", "am", "pm", "ಕಾಂಡೆ", "ಮಧ್ಯಾಹ್ನ", "ಬಯ್ಯ", "ರಾತ್ರೆ"],
      "separator": ":",
      "pattern_template": "({digits}{1,2}):({digits}{2})(?:\\s*({periods}))?",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "periods": "{period_alternation}"
      },
      "ssml": {
        "interpret_as": "time",
        "attributes": {
          "format": "hms12"
        },
        "template": "<say-as interpret-as=\"time\" format=\"hms12\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["೫:೩೦", "14:30", "5:30 PM", "೩:೦೦ ಕಾಂಡೆ"],
        "negative": ["530", "5.30", "25:61"]
      }
    },

    "units": {
      "description": "Measurement units (e.g., ೫ ಕಿಲೋಗ್ರಾಂ, 100 km)",
      "unit_map": {
        "kg": "ಕಿಲೋಗ್ರಾಂ",
        "g": "ಗ್ರಾಂ",
        "km": "ಕಿಲೋಮೀಟರ್",
        "m": "ಮೀಟರ್",
        "cm": "ಸೆಂಟಿಮೀಟರ್",
        "mm": "ಮಿಲಿಮೀಟರ್",
        "l": "ಲೀಟರ್",
        "ml": "ಮಿಲಿಲೀಟರ್",
        "°C": "ಡಿಗ್ರಿ ಸೆಲ್ಸಿಯಸ್",
        "°F": "ಡಿಗ್ರಿ ಫ್ಯಾರನ್‌ಹೀಟ್",
        "ಕಿಲೋಗ್ರಾಂ": "ಕಿಲೋಗ್ರಾಂ",
        "ಗ್ರಾಂ": "ಗ್ರಾಂ",
        "ಕಿಲೋಮೀಟರ್": "ಕಿಲೋಮೀಟರ್",
        "ಮೀಟರ್": "ಮೀಟರ್",
        "ಸೆಂಟಿಮೀಟರ್": "ಸೆಂಟಿಮೀಟರ್",
        "ಲೀಟರ್": "ಲೀಟರ್",
        "ಮಿಲಿಲೀಟರ್": "ಮಿಲಿಲೀಟರ್"
      },
      "pattern_template": "({digits}+(?:\\.{digits}+)?)\\s*({unit_names})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "unit_names": "{unit_alternation}"
      },
      "ssml": {
        "interpret_as": "unit",
        "template": "<say-as interpret-as=\"unit\">{value} {unit_spoken}</say-as>"
      },
      "test_cases": {
        "positive": ["೫ ಕಿಲೋಗ್ರಾಂ", "100 km", "೧.೫ ಲೀಟರ್"],
        "negative": ["ಕಿಲೋಗ್ರಾಂ", "100", "km"]
      }
    }
  }
}
