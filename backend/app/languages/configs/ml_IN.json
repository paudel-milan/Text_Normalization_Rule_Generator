  "categories": {
    "cardinal": {
      "description": "Cardinal numbers (e.g., ൫൦൦, 1234)",
      "pattern_template": "({digits}+)",
      "tokens": {
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "cardinal",
        "template": "<say-as interpret-as=\"cardinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["൫൦൦", "൧൨൩൪", "100", "൦"],
        "negative": ["abc", "₹൫൦൦", ""]
      }
    },

    "ordinal": {
      "description": "Ordinal numbers (e.g., ൫-ാം, 3-ാം)",
      "suffixes": ["ാം", "ാമത്തെ"],
      "pattern_template": "({digits}+)\\s*-?\\s*({suffixes})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "suffixes": "{suffix_alternation}"
      },
      "ssml": {
        "interpret_as": "ordinal",
        "template": "<say-as interpret-as=\"ordinal\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["൫-ാം", "൧ാം", "10-ാമത്തെ", "3ാം"],
        "negative": ["൫", "ാം", "abc"]
      }
    },

    "currency": {
      "description": "Currency amounts (e.g., ₹൫൦൦, $100.50)",
      "symbols": ["₹", "$"],
      "symbol_names": {
        "₹": "രൂപ",
        "$": "ഡോളർ"
      },
      "decimal_separator": ".",
      "pattern_template": "({symbols})\\s*({digits}+)(?:\\.({digits}+))?",
      "tokens": {
        "symbols": "[{symbol_chars}]",
        "digits": "[0-9{native_digit_range}]"
      },
      "ssml": {
        "interpret_as": "currency",
        "attributes": {
          "currency": "INR"
        },
        "template": "<say-as interpret-as=\"currency\">{value}</say-as>"
      },
      "normalization": {
        "format": "{amount_words} {currency_name}"
      },
      "test_cases": {
        "positive": ["₹൫൦൦", "₹൧൦", "$100", "₹50.75", "₹ 200"],
        "negative": ["500", "രൂപ", "₹"]
      }
    },

    "date": {
      "description": "Date expressions (e.g., ൧൫/൦൮/൨൦൨൩, 15-08-2023)",
      "separators": ["/", "-", "."],
      "month_names": [
        "ജനുവരി", "ഫെബ്രുവരി", "മാർച്ച്", "ഏപ്രിൽ", "മേയ്", "ജൂൺ",
        "ജൂലൈ", "ഓഗസ്റ്റ്", "സെപ്റ്റംബർ", "ഒക്ടോബർ", "നവംബർ", "ഡിസംബർ"
      ],
      "format_order": "DMY",
      "pattern_template": "({digits}{1,2}){separator}({digits}{1,2}){separator}({digits}{2,4})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "separator": "[{separator_chars}]"
      },
      "ssml": {
        "interpret_as": "date",
        "attributes": {
          "format": "dmy"
        },
        "template": "<say-as interpret-as=\"date\" format=\"dmy\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["൧൫/൦൮/൨൦൨൩", "15-08-2023", "01.12.2024"],
        "negative": ["15082023", "abc", "date-text"]
      }
    },

    "time": {
      "description": "Time expressions (e.g., ൫:൩൦, 14:30, 5:30 PM)",
      "period_markers": ["AM", "PM", "am", "pm", "രാവിലെ", "വൈകുന്നേരം", "ഉച്ച", "രാത്രി"],
      "separator": ":",
      "pattern_template": "({digits}{1,2}):({digits}{2})(?:\\s*({periods}))?",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "periods": "{period_alternation}"
      },
      "ssml": {
        "interpret_as": "time",
        "attributes": {
          "format": "hms12"
        },
        "template": "<say-as interpret-as=\"time\" format=\"hms12\">{value}</say-as>"
      },
      "test_cases": {
        "positive": ["൫:൩൦", "14:30", "5:30 PM", "൩:൦൦ രാവിലെ"],
        "negative": ["530", "5.30", "time-text"]
      }
    },

    "units": {
      "description": "Measurement units (e.g., ൫ കിലോഗ്രാം, 100 km)",
      "unit_map": {
        "kg": "കിലോഗ്രാം",
        "g": "ഗ്രാം",
        "km": "കിലോമീറ്റർ",
        "m": "മീറ്റർ",
        "cm": "സെന്റിമീറ്റർ",
        "mm": "മില്ലിമീറ്റർ",
        "l": "ലിറ്റർ",
        "ml": "മില്ലിലിറ്റർ",
        "°C": "ഡിഗ്രി സെൽഷ്യസ്",
        "°F": "ഡിഗ്രി ഫാരൻഹീറ്റ്",
        "km/h": "കിലോമീറ്റർ മണിക്കൂറിൽ",
        "mph": "മൈൽ മണിക്കൂറിൽ",
        "കിലോഗ്രാം": "കിലോഗ്രാം",
        "ഗ്രാം": "ഗ്രാം",
        "കിലോമീറ്റർ": "കിലോമീറ്റർ",
        "മീറ്റർ": "മീറ്റർ",
        "സെന്റിമീറ്റർ": "സെന്റിമീറ്റർ",
        "ലിറ്റർ": "ലിറ്റർ",
        "മില്ലിലിറ്റർ": "മില്ലിലിറ്റർ"
      },
      "pattern_template": "({digits}+(?:\\.{digits}+)?)\\s*({unit_names})",
      "tokens": {
        "digits": "[0-9{native_digit_range}]",
        "unit_names": "{unit_alternation}"
      },
      "ssml": {
        "interpret_as": "unit",
        "template": "<say-as interpret-as=\"unit\">{value} {unit_spoken}</say-as>"
      },
      "test_cases": {
        "positive": ["൫ കിലോഗ്രാം", "100 km", "37.5 °C", "൧.൫ ലിറ്റർ"],
        "negative": ["കിലോഗ്രാം", "100", "km"]
      }
    }
  }
}
